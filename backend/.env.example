# ══════════════════════════════════════════════════════════════════
# Tani Tinggi Backend — Environment Variables
# Copy to .env and fill in your values
# ══════════════════════════════════════════════════════════════════

# App
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# Database (PostgreSQL 15)
DATABASE_URL=postgresql://tanitinggi:secret@localhost:5432/tanitinggi_db

# Redis 7 (BullMQ + cache)
REDIS_URL=redis://localhost:6379

# Auth — RSA keys for JWT RS256 (generate with: npm run generate:keys)
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# AI Model
TF_MODEL_PATH=./models/plant_validator/model.json
TF_MODEL_URL=https://storage.googleapis.com/tanitinggi-models/plant-mobilenet/model.json
AI_CONFIDENCE_THRESHOLD=0.75
AI_MODEL_VERSION=1.0.0

# Blockchain — Polygon Amoy Testnet (chainId: 80002)
POLYGON_RPC_URL=https://rpc-amoy.polygon.technology
POLYGON_PRIVATE_KEY=your_wallet_private_key_here
CONTRACT_ADDRESS=deployed_contract_address_here
CHAIN_ID=80002

# Storage — Cloudinary (free tier)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=tanitinggi

# Carbon Score Config
CARBON_CALCULATION_VERSION=1.0.0
# Emission factors (kg CO2 per km per kg of cargo)
# Based on EPA GHG Emission Factors Hub 2025
EMISSION_MOTORCYCLE=0.000103
EMISSION_PICKUP=0.000097
EMISSION_MEDIUM_TRUCK=0.000072
EMISSION_HEAVY_TRUCK=0.000062
EMISSION_ELECTRIC=0.000015

# Eco-Score Grade Thresholds (total kg CO2e)
GRADE_A_MAX_KG=2.0
GRADE_B_MAX_KG=5.0
GRADE_C_MAX_KG=10.0
GRADE_D_MAX_KG=20.0

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3001,https://tanitinggi.app

# Logging
LOG_LEVEL=info
