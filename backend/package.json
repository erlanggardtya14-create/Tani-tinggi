{
  "name": "tanitinggi-backend",
  "version": "1.0.0",
  "description": "Tani Tinggi — Platform sertifikasi sayuran dataran tinggi ramah lingkungan berbasis AI dan Blockchain",
  "main": "dist/app.js",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "dev:worker": "tsx watch src/workers/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/app.js",
    "start:worker": "node dist/workers/index.js",
    "start:prod": "pm2-runtime ecosystem.config.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:prod": "prisma migrate deploy",
    "prisma:seed": "tsx prisma/seed.ts",
    "prisma:studio": "prisma studio",
    "docker:dev": "docker compose up -d",
    "docker:prod": "docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d --build",
    "generate:keys": "tsx scripts/generate-keys.ts",
    "deploy:contract": "tsx scripts/deploy-contract.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/jwt": "^8.0.0",
    "@fastify/multipart": "^8.1.0",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/swagger": "^8.14.0",
    "@fastify/swagger-ui": "^3.0.0",
    "@openzeppelin/contracts": "^5.0.2",
    "@prisma/client": "^5.17.0",
    "@tensorflow-models/mobilenet": "^2.1.1",
    "@tensorflow/tfjs": "^4.22.0",
    "bullmq": "^5.8.0",
    "cloudinary": "^1.41.3",
    "dotenv": "^17.4.2",
    "ethers": "^6.13.0",
    "fastify": "^4.28.0",
    "fastify-type-provider-zod": "^6.1.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "pino": "^9.2.0",
    "pino-pretty": "^11.2.1",
    "qrcode": "^1.5.3",
    "sharp": "^0.35.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.0",
    "@types/qrcode": "^1.5.5",
    "hardhat": "^2.22.0",
    "prisma": "^5.17.0",
    "supertest": "^7.0.0",
    "tsx": "^4.15.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT"
}
