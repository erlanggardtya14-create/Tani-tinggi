# Frontend Tani Tinggi — environment (opsional, semua punya default)
# Salin ke .env bila perlu override.

# Base URL API. Default '/api/v1' (lewat proxy Vite ke backend :3000).
# Untuk produksi/backend terpisah, isi URL penuh, mis: https://api.tanitinggi.app/api/v1
VITE_API_BASE=/api/v1

# Target proxy dev (dipakai vite.config.ts). Default http://localhost:3000
VITE_PROXY_TARGET=http://localhost:3000

# Kredensial petani demo untuk auto-login (hasil prisma:seed).
VITE_DEMO_EMAIL=dieng@tanitinggi.id
VITE_DEMO_PASSWORD=Farmer1234!
